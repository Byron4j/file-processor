# FileMaster Pro - Production Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to version control

# ============================================
# Domain Configuration
# ============================================
DOMAIN=your-domain.com
EMAIL=admin@your-domain.com

# ============================================
# Database Configuration
# ============================================
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=filemaster
MYSQL_USER=filemaster
MYSQL_PASSWORD=your_secure_mysql_password
MYSQL_ROOT_PASSWORD=your_secure_root_password

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password

# ============================================
# Alipay Configuration
# Get these from: https://open.alipay.com/
# ============================================
ALIPAY_APP_ID=2024XXXXXXXXXXXX
# Private key (RSA2 format, keep the newlines as \n)
ALIPAY_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEpQIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----
# Alipay public key (NOT your app's public key)
ALIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...\n-----END PUBLIC KEY-----
ALIPAY_SERVER_URL=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/alipay/notify
ALIPAY_RETURN_URL=https://your-domain.com/payment/success

# ============================================
# WeChat Pay Configuration
# Get these from: https://pay.weixin.qq.com/
# ============================================
WECHAT_MCH_ID=1234567890
WECHAT_APP_ID=wx1234567890abcdef
# API v3 Key - 32 character key from WeChat Pay platform
WECHAT_API_V3_KEY=Your32CharacterLongKeyHere!!
# Certificate serial number - 34 character hex string
WECHAT_MCH_SERIAL_NO=1234567890ABCDEF1234567890ABCDEF12
# Path to apiclient_key.pem inside the container
WECHAT_PRIVATE_KEY_PATH=/etc/filemaster/certs/apiclient_key.pem
WECHAT_NOTIFY_URL=https://your-domain.com/api/payment/wechat/notify

# ============================================
# Storage Configuration
# ============================================
STORAGE_TYPE=local
STORAGE_BASE_PATH=/data/filemaster/files

# MinIO Configuration (if STORAGE_TYPE=minio)
# MINIO_ENDPOINT=http://minio:9000
# MINIO_ACCESS_KEY=your_access_key
# MINIO_SECRET_KEY=your_secret_key
# MINIO_BUCKET=filemaster
